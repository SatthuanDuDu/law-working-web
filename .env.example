AUTH_SECRET="change-me-to-a-long-random-string"
# Production: set to your public URL (e.g. https://luat-work.vercel.app)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Postgres — local docker OR Neon pooled connection string
# Neon example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://luat:luat@localhost:5432/luat_work?schema=public"

# Postgres (docker-compose local)
POSTGRES_USER=luat
POSTGRES_PASSWORD=luat
POSTGRES_DB=luat_work
POSTGRES_PORT=5432

# Object storage — local MinIO OR Cloudflare R2 (S3-compatible)
# R2 example endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT="http://localhost:9000"
S3_PUBLIC_ENDPOINT="http://localhost:9000"
S3_BUCKET="luat-attachments"
S3_ACCESS_KEY="luatminio"
S3_SECRET_KEY="luatminio123"
S3_REGION="auto"

# Cron job protection (Vercel Cron /api/cron/deadlines)
CRON_SECRET="change-me-cron-secret"

# OpenAI (AI tóm tắt vụ việc)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Production (optional self-host)
# DOMAIN=work.luat.vn
# APP_PORT=3000
