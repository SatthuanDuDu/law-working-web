    "jobs:deadlines": "tsx src/lib/jobs/generate-deadline-notifications.ts",
    "docker:deps": "docker compose up -d db minio minio-init",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
