    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^6.2.2",
    "recharts": "^3.9.2",
