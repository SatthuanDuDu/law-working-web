generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  LAWYER
  SUPPORT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MatterStatus {
  NEW
  IN_PROGRESS
  ON_HOLD
  CLOSED
  ARCHIVED
}

enum MatterType {
  CIVIL
  CRIMINAL
  CORPORATE
  LABOR
  FAMILY
  OTHER
}

enum ClientBusinessType {
  LLC
  JSC
  SOLE_PROPRIETOR
  PARTNERSHIP
  INDIVIDUAL
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum MatterPlanStepStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_DUE
  GENERAL
  MENTION
  CHAT_MESSAGE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum ConversationType {
  DIRECT
  GROUP
  ALL
}

enum ExpenseType {
  COURT_FEE
  NOTARY
  TRAVEL
  TRANSLATION
  DOCUMENT
  EXPERTISE
  OTHER
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id                     String               @id @default(cuid())
  username               String               @unique
  email                  String               @unique
  password               String
  name                   String
  phone                  String?
  dateOfBirth            DateTime?
  gender                 Gender?
  role                   Role                 @default(SUPPORT)
  departmentId           String?
  department             Department?          @relation(fields: [departmentId], references: [id])
  avatarKey              String?
  isActive               Boolean              @default(true)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  assignedTasks          Task[]               @relation("AssignedTasks")
  createdTasks           Task[]               @relation("CreatedTasks")
  ledMatters             Matter[]             @relation("LeadLawyer")
  matterMembers          MatterMember[]
  notifications          Notification[]
  auditLogs              AuditLog[]
  uploadedFiles          Attachment[]
  comments               Comment[]
  commentMentions        CommentMention[]
  conversationsCreated   Conversation[]       @relation("ConversationCreator")
  conversationMembers    ConversationMember[]
  chatMessages           ChatMessage[]
  chatMessageMentions    ChatMessageMention[]
  matterExpenses         MatterExpense[]
}

model Client {
  id           String              @id @default(cuid())
  code         String              @unique
  name         String
  email        String?
  phone        String?
  address      String?
  city         String?
  businessType ClientBusinessType?
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  matters      Matter[]
  attachments  Attachment[]
}

model Matter {
  id           String         @id @default(cuid())
  code         String         @unique
  title        String
  description  String?
  type            MatterType     @default(OTHER)
  customTypeLabel String?
  status          MatterStatus   @default(NEW)
  clientId     String
  client       Client         @relation(fields: [clientId], references: [id])
  leadLawyerId String
  leadLawyer   User           @relation("LeadLawyer", fields: [leadLawyerId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  members      MatterMember[]
  planSteps    MatterPlanStep[]
  tasks        Task[]
  attachments  Attachment[]
  comments     Comment[]
  expenses     MatterExpense[]
  @@index([leadLawyerId])
  @@index([clientId])
  @@index([updatedAt])
}

model MatterExpense {
  id              String      @id @default(cuid())
  matterId        String
  matter          Matter      @relation(fields: [matterId], references: [id], onDelete: Cascade)
  type            ExpenseType
  customTypeLabel String?
  amountVnd       BigInt
  createdById     String
  createdBy       User        @relation(fields: [createdById], references: [id])
  createdAt       DateTime    @default(now())

  @@index([matterId, createdAt])
  @@index([createdById])
}

model MatterPlanStep {
  id               String                @id @default(cuid())
  matterId         String
  matter           Matter                @relation(fields: [matterId], references: [id], onDelete: Cascade)
  title            String
  workTypeId       String?
  workType         WorkType?             @relation(fields: [workTypeId], references: [id], onDelete: SetNull)
  startedAt        DateTime?
  dueAt            DateTime?
  status           MatterPlanStepStatus  @default(NOT_STARTED)
  priority         TaskPriority          @default(MEDIUM)
  statusChangedAt  DateTime?
  sortOrder        Int                   @default(0)
  locationName     String?
  locationAddress  String?
  locationPlaceId  String?
  locationLat      Float?
  locationLng      Float?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  comments         Comment[]
  attachments      Attachment[]

  @@index([matterId, sortOrder])
}

model MatterMember {
  id        String   @id @default(cuid())
  matterId  String
  userId    String
  matter    Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([matterId, userId])
  @@index([userId])
}

model WorkType {
  id        String     @id @default(cuid())
  name      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  planSteps MatterPlanStep[]
}

model AttachmentLabel {
  id          String       @id @default(cuid())
  name        String       @unique
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  reminderSentAt DateTime?
  assigneeId     String
  assignee       User         @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdById    String
  createdBy      User         @relation("CreatedTasks", fields: [createdById], references: [id])
  matterId       String?
  matter         Matter?      @relation(fields: [matterId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  attachments    Attachment[]

  @@index([assigneeId])
  @@index([dueDate])
  @@index([status])
  @@index([matterId])
}

model Attachment {
  id               String           @id @default(cuid())
  fileName         String
  mimeType         String
  sizeBytes        Int
  storageKey       String
  matterId         String?
  matter           Matter?          @relation(fields: [matterId], references: [id], onDelete: Cascade)
  taskId           String?
  task             Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  clientId         String?
  client           Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  matterPlanStepId String?
  matterPlanStep   MatterPlanStep?  @relation(fields: [matterPlanStepId], references: [id], onDelete: Cascade)
  commentId        String?
  comment          Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  conversationId   String?
  conversation     Conversation?    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  chatMessageId    String?
  chatMessage      ChatMessage?     @relation(fields: [chatMessageId], references: [id], onDelete: Cascade)
  labelId          String?
  label            AttachmentLabel? @relation(fields: [labelId], references: [id], onDelete: SetNull)
  customLabel      String?
  isImportant      Boolean          @default(false)
  uploadedById     String
  uploadedBy       User             @relation(fields: [uploadedById], references: [id])
  createdAt        DateTime         @default(now())

  @@index([matterPlanStepId])
  @@index([commentId])
  @@index([conversationId])
  @@index([chatMessageId])
  @@index([labelId])
  @@index([isImportant])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(GENERAL)
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

model Comment {
  id               String           @id @default(cuid())
  matterId         String
  matter           Matter           @relation(fields: [matterId], references: [id], onDelete: Cascade)
  matterPlanStepId String?
  matterPlanStep   MatterPlanStep?  @relation(fields: [matterPlanStepId], references: [id], onDelete: Cascade)
  authorId         String
  author           User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body             String
  locationName     String?
  locationAddress  String?
  locationPlaceId  String?
  locationLat      Float?
  locationLng      Float?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  mentions         CommentMention[]
  attachments      Attachment[]

  @@index([matterId, createdAt])
  @@index([matterPlanStepId, createdAt])
}

model CommentMention {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
  @@index([userId])
}

model Conversation {
  id          String               @id @default(cuid())
  type        ConversationType
  name        String?
  createdById String
  createdBy   User                 @relation("ConversationCreator", fields: [createdById], references: [id])
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     ConversationMember[]
  messages    ChatMessage[]
  attachments Attachment[]

  @@index([updatedAt])
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
}

model ChatMessage {
  id               String               @id @default(cuid())
  conversationId   String
  conversation     Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId         String
  sender           User                 @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body             String               @default("")
  locationName     String?
  locationAddress  String?
  locationPlaceId  String?
  locationLat      Float?
  locationLng      Float?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  mentions         ChatMessageMention[]
  attachments      Attachment[]

  @@index([conversationId, createdAt])
}

model ChatMessageMention {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([messageId, userId])
  @@index([userId])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String
  entityId   String?
  details    String?
  createdAt  DateTime    @default(now())
}
