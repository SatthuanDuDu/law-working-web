generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  LAWYER
  SUPPORT
}

enum MatterStatus {
  NEW
  IN_PROGRESS
  ON_HOLD
  CLOSED
}

enum MatterType {
  CIVIL
  CRIMINAL
  CORPORATE
  LABOR
  FAMILY
  OTHER
}

enum ClientBusinessType {
  LLC
  JSC
  SOLE_PROPRIETOR
  PARTNERSHIP
  INDIVIDUAL
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum MatterPlanStepStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_DUE
  GENERAL
  MENTION
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  password         String
  name             String
  role             Role           @default(SUPPORT)
  departmentId     String?
  department       Department?    @relation(fields: [departmentId], references: [id])
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  assignedTasks    Task[]         @relation("AssignedTasks")
  createdTasks     Task[]         @relation("CreatedTasks")
  ledMatters       Matter[]       @relation("LeadLawyer")
  matterMembers    MatterMember[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  uploadedFiles    Attachment[]
  comments         Comment[]
  commentMentions  CommentMention[]
}

model Client {
  id           String              @id @default(cuid())
  name         String
  email        String?
  phone        String?
  address      String?
  city         String?
  businessType ClientBusinessType?
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  matters      Matter[]
  attachments  Attachment[]
}

model Matter {
  id           String         @id @default(cuid())
  code         String         @unique
  title        String
  description  String?
  type            MatterType     @default(OTHER)
  customTypeLabel String?
  status          MatterStatus   @default(NEW)
  clientId     String
  client       Client         @relation(fields: [clientId], references: [id])
  leadLawyerId String
  leadLawyer   User           @relation("LeadLawyer", fields: [leadLawyerId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  members      MatterMember[]
  planSteps    MatterPlanStep[]
  tasks        Task[]
  attachments  Attachment[]
  comments     Comment[]
  @@index([leadLawyerId])
  @@index([clientId])
  @@index([updatedAt])
}

model MatterPlanStep {
  id              String                @id @default(cuid())
  matterId        String
  matter          Matter                @relation(fields: [matterId], references: [id], onDelete: Cascade)
  title           String
  workTypeId      String?
  workType        WorkType?             @relation(fields: [workTypeId], references: [id], onDelete: SetNull)
  startedAt       DateTime?
  dueAt           DateTime?
  status          MatterPlanStepStatus  @default(NOT_STARTED)
  statusChangedAt DateTime?
  sortOrder       Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  comments        Comment[]

  @@index([matterId, sortOrder])
}

model MatterMember {
  id        String   @id @default(cuid())
  matterId  String
  userId    String
  matter    Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([matterId, userId])
  @@index([userId])
}

model WorkType {
  id        String     @id @default(cuid())
  name      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  planSteps MatterPlanStep[]
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  reminderSentAt DateTime?
  assigneeId     String
  assignee       User         @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdById    String
  createdBy      User         @relation("CreatedTasks", fields: [createdById], references: [id])
  matterId       String?
  matter         Matter?      @relation(fields: [matterId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  attachments    Attachment[]

  @@index([assigneeId])
  @@index([dueDate])
  @@index([status])
  @@index([matterId])
}

model Attachment {
  id           String    @id @default(cuid())
  fileName     String
  mimeType     String
  sizeBytes    Int
  storageKey   String
  matterId     String?
  matter       Matter?   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  taskId       String?
  task         Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  clientId     String?
  client       Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime  @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(GENERAL)
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

model Comment {
  id               String           @id @default(cuid())
  matterId         String
  matter           Matter           @relation(fields: [matterId], references: [id], onDelete: Cascade)
  matterPlanStepId String?
  matterPlanStep   MatterPlanStep?  @relation(fields: [matterPlanStepId], references: [id], onDelete: Cascade)
  authorId         String
  author           User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body             String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  mentions         CommentMention[]

  @@index([matterId, createdAt])
  @@index([matterPlanStepId, createdAt])
}

model CommentMention {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
  @@index([userId])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String
  entityId   String?
  details    String?
  createdAt  DateTime    @default(now())
}
